@page "/CircleArea"
@using BlazorApp_Jimena.IApiService
@using BlazorApp_Jimena.Service
@using Modelo.RequestEntity
@inject ICircleService api

<h3>Area de un circulo</h3>
<hr/>

<p>Introduce un color: </p>
<input @bind="color" placeholder="Color"/>

<p>Intoduce el radio del circulo: </p>
<input @bind="radio" placeholder="Radio"/>
<button type="button" @onclick="CalcularAreaCircle">Calcular</button>

<p>El area del circulo es: <strong>@area</strong> y el color es: @color</p>

@code {

    private double radio { get; set; }
    private string color { get; set; }
    private double area { get; set; }

    async Task CalcularAreaCircle()
    {
        try
        {
            CircleRequest request = new CircleRequest { Color = color, Radius = radio };
            var result = await api.GetCircleArea(request);
            area = result.Area;

        }
        catch(Exception e)
        {
            Console.WriteLine("Error: " + e.Message);
        }
    }
}
